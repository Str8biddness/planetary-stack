    },
    "state": {
      "$ref": "#/$defs/LeaseState"
    },
    "transport": {
      "$ref": "#/$defs/TransportKind"
    },
    "ttl_seconds": {
      "maximum": 900,
      "minimum": 1,
      "title": "Ttl Seconds",
      "type": "integer"
    }
