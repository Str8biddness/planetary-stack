{
  "$defs": {
    "LeaseRevocationReason": {
      "enum": [
        "owner_request",
        "policy_change",
        "capability_revoked",
        "node_health",
        "integrity_failure",
        "lease_superseded"
      ],
      "title": "LeaseRevocationReason",
      "type": "string"
    },
    "LeaseState": {
      "enum": [
        "pending",
        "active",
        "released",
        "expired",
        "revoked"
      ],
      "title": "LeaseState",
      "type": "string"
    },
    "ResourceVector": {
      "additionalProperties": false,
      "allOf": [
        {
          "else": {
            "properties": {
              "gpu_memory_bytes": {
                "minimum": 1
              }
            }
          },
          "if": {
            "properties": {
              "gpu_count": {
                "const": 0
              }
            },
            "required": [
              "gpu_count"
            ]
          },
          "then": {
            "properties": {
              "gpu_memory_bytes": {
                "const": 0
              }
            }
          }
        }
      ],
      "properties": {
        "cpu_millicores": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Cpu Millicores",
          "type": "integer"
        },
        "egress_bps": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Egress Bps",
          "type": "integer"
        },
        "gpu_count": {
          "maximum": 64,
          "minimum": 0,
          "title": "Gpu Count",
          "type": "integer"
        },
        "gpu_memory_bytes": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Gpu Memory Bytes",
          "type": "integer"
        },
        "ingress_bps": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Ingress Bps",
          "type": "integer"
        },
        "memory_bytes": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Memory Bytes",
          "type": "integer"
        },
        "storage_bytes": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Storage Bytes",
          "type": "integer"
        }
      },
      "required": [
        "cpu_millicores",
        "egress_bps",
        "gpu_count",
        "gpu_memory_bytes",
        "ingress_bps",
        "memory_bytes",
        "storage_bytes"
      ],
      "title": "ResourceVector",
      "type": "object"
    },
    "Signature": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "ed25519",
          "title": "Algorithm",
          "type": "string"
        },
        "key_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
          "title": "Key Id",
          "type": "string"
        },
        "value": {
          "maxLength": 86,
          "minLength": 86,
          "pattern": "^[A-Za-z0-9_-]{86}$(?![\\s\\S])",
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "key_id",
        "value"
      ],
      "title": "Signature",
      "type": "object"
    },
    "TransportKind": {
      "enum": [
        "local_process",
        "unix_socket",
        "lan_mtls",
        "internet_mtls_relay",
        "qualified_rdma"
      ],
