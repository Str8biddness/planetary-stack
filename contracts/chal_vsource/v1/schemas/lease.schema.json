  "properties": {
    "account_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Account Id",
      "type": "string"
    },
    "capability_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Capability Id",
      "type": "string"
    },
    "fencing_token": {
      "maximum": 9007199254740991,
      "minimum": 1,
      "title": "Fencing Token",
      "type": "integer"
    },
    "gpu_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 3,
        "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
        "type": "string"
      },
      "maxItems": 64,
      "title": "Gpu Ids",
      "type": "array",
      "uniqueItems": true,
      "x-canonical-order": "lexicographic"
    },
    "inventory_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Inventory Id",
      "type": "string"
    },
    "inventory_sha256": {
      "pattern": "^[a-f0-9]{64}$(?![\\s\\S])",
      "title": "Inventory Sha256",
      "type": "string"
    },
    "lease_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Lease Id",
      "type": "string"
    },
    "node_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Node Id",
      "type": "string"
    },
    "not_before": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$(?![\\s\\S])",
      "title": "Not Before",
      "type": "string"
    },
    "placement_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Placement Id",
      "type": "string"
    },
    "renewal_sequence": {
      "maximum": 1024,
      "minimum": 0,
      "title": "Renewal Sequence",
      "type": "integer"
    },
    "renewals_remaining": {
      "maximum": 1024,
      "minimum": 0,
      "title": "Renewals Remaining",
      "type": "integer"
    },
    "request_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Request Id",
      "type": "string"
    },
    "request_sha256": {
      "pattern": "^[a-f0-9]{64}$(?![\\s\\S])",
      "title": "Request Sha256",
      "type": "string"
    },
    "resources": {
      "$ref": "#/$defs/ResourceVector"
    },
    "revocation_reason": {
      "anyOf": [
