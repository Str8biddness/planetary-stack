{
  "$defs": {
    "ContentReference": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "default": "private",
          "enum": [
            "public",
            "private",
            "restricted"
          ],
          "title": "Classification",
          "type": "string"
        },
        "media_type": {
          "maxLength": 128,
          "minLength": 3,
          "title": "Media Type",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "uri": {
          "maxLength": 512,
          "minLength": 8,
          "pattern": "^(artifact|aivm|chal|kc|mem)://[A-Za-z0-9][A-Za-z0-9._~:/?#@!$&'()*+,;=%-]*$",
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "uri",
        "sha256",
        "size_bytes",
        "media_type"
      ],
      "title": "ContentReference",
      "type": "object"
    },
    "ErrorCode": {
      "enum": [
        "invalid_request",
        "unauthorized",
        "forbidden",
        "capability_expired",
        "capability_revoked",
        "no_placement",
        "lease_conflict",
        "lease_expired",
        "node_unavailable",
        "transport_unavailable",
        "resource_exhausted",
        "workload_rejected",
        "workload_failed",
        "integrity_failure",
        "attestation_failed",
        "deadline_exceeded",
        "internal_error"
      ],
      "title": "ErrorCode",
      "type": "string"
    },
    "ErrorFrame": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/$defs/ErrorCode"
        },
        "device_uri": {
          "anyOf": [
            {
              "pattern": "^chal://[A-Za-z0-9._~:/-]+$",
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Device Uri"
        },
        "error_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "title": "Error Id",
          "type": "string"
        },
        "request_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "title": "Request Id",
          "type": "string"
        },
        "retry_after_ms": {
          "anyOf": [
            {
              "maximum": 3600000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Retry After Ms"
        },
        "retryable": {
          "title": "Retryable",
          "type": "boolean"
        },
        "safe_detail": {
          "maxLength": 512,
          "minLength": 1,
          "title": "Safe Detail",
          "type": "string"
        },
        "schema": {
          "const": "planetary.chal.error.v1",
          "default": "planetary.chal.error.v1",
          "title": "Schema",
          "type": "string"
        },
        "trace_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "title": "Trace Id",
          "type": "string"
        }
      },
      "required": [
        "error_id",
        "request_id",
        "trace_id",
        "code",
        "retryable",
        "safe_detail"
      ],
      "title": "ErrorFrame",
      "type": "object"
    },
    "ResponseStatus": {
      "enum": [
        "succeeded",
        "degraded",
        "rejected",
        "failed"
      ],
      "title": "ResponseStatus",
      "type": "string"
    }
  },
  "$id": "https://schemas.reality-core.systems/chal-vsource/v1/chal-response.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "completed_at": {
      "format": "date-time",
      "title": "Completed At",
      "type": "string"
    },
    "device_uri": {
      "pattern": "^chal://[A-Za-z0-9._~:/-]+$",
      "title": "Device Uri",
      "type": "string"
    },
    "error": {
      "anyOf": [
        {
          "$ref": "#/$defs/ErrorFrame"
        },
        {
          "type": "null"
        }
      ],
      "default": null
    },
    "outputs": {
      "items": {
        "$ref": "#/$defs/ContentReference"
      },
      "maxItems": 128,
      "title": "Outputs",
      "type": "array"
    },
    "request_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Request Id",
      "type": "string"
    },
    "response_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Response Id",
      "type": "string"
    },
    "schema": {
      "const": "planetary.chal.response.v1",
      "default": "planetary.chal.response.v1",
      "title": "Schema",
      "type": "string"
    },
    "status": {
      "$ref": "#/$defs/ResponseStatus"
    },
    "telemetry_ids": {
      "items": {
        "maxLength": 128,
        "minLength": 3,
        "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
        "type": "string"
      },
      "maxItems": 256,
      "title": "Telemetry Ids",
      "type": "array"
    },
    "trace_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Trace Id",
      "type": "string"
    }
  },
  "required": [
    "response_id",
    "request_id",
    "trace_id",
    "device_uri",
    "status",
    "completed_at"
  ],
  "title": "ChalResponse",
  "type": "object"
}
