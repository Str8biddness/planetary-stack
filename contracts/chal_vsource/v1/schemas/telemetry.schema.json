{
  "$defs": {
    "ResourceVector": {
      "additionalProperties": false,
      "properties": {
        "cpu_millicores": {
          "default": 0,
          "minimum": 0,
          "title": "Cpu Millicores",
          "type": "integer"
        },
        "egress_bps": {
          "default": 0,
          "minimum": 0,
          "title": "Egress Bps",
          "type": "integer"
        },
        "gpu_count": {
          "default": 0,
          "minimum": 0,
          "title": "Gpu Count",
          "type": "integer"
        },
        "gpu_memory_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Gpu Memory Bytes",
          "type": "integer"
        },
        "ingress_bps": {
          "default": 0,
          "minimum": 0,
          "title": "Ingress Bps",
          "type": "integer"
        },
        "memory_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Memory Bytes",
          "type": "integer"
        },
        "storage_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Storage Bytes",
          "type": "integer"
        }
      },
      "title": "ResourceVector",
      "type": "object"
    },
    "TelemetryLabels": {
      "additionalProperties": false,
      "description": "Bounded operational dimensions; user content has no label field.",
      "properties": {
        "accelerator": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Accelerator"
        },
        "backend": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Backend"
        },
        "degradation_reason": {
          "anyOf": [
            {
              "maxLength": 128,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Degradation Reason"
        },
        "region": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Region"
        },
        "route": {
          "anyOf": [
            {
              "maxLength": 64,
              "minLength": 1,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Route"
        },
        "verification": {
          "anyOf": [
            {
              "enum": [
                "unverified",
                "verified",
                "rejected"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Verification"
        }
      },
      "title": "TelemetryLabels",
      "type": "object"
    },
    "TelemetryPhase": {
      "enum": [
        "admission",
        "queue",
        "transfer",
        "execution",
        "checkpoint",
        "verification",
        "release"
      ],
      "title": "TelemetryPhase",
      "type": "string"
    }
  },
  "$id": "https://schemas.reality-core.systems/chal-vsource/v1/telemetry.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "contains_user_content": {
      "const": false,
      "default": false,
      "title": "Contains User Content",
      "type": "boolean"
    },
    "error_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error Id"
    },
    "input_sha256": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Input Sha256"
    },
    "labels": {
      "$ref": "#/$defs/TelemetryLabels"
    },
    "latency_ms": {
      "default": 0.0,
      "minimum": 0.0,
      "title": "Latency Ms",
      "type": "number"
    },
    "measurement_kind": {
      "enum": [
        "measured",
        "estimated"
      ],
      "title": "Measurement Kind",
      "type": "string"
    },
    "node_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Node Id"
    },
    "output_sha256": {
      "anyOf": [
        {
          "pattern": "^[a-f0-9]{64}$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Output Sha256"
    },
    "phase": {
      "$ref": "#/$defs/TelemetryPhase"
    },
    "queue_ms": {
      "default": 0.0,
      "minimum": 0.0,
      "title": "Queue Ms",
      "type": "number"
    },
    "recorded_at": {
      "format": "date-time",
      "title": "Recorded At",
      "type": "string"
    },
    "request_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Request Id",
      "type": "string"
    },
    "schema": {
      "const": "planetary.chal.telemetry.v1",
      "default": "planetary.chal.telemetry.v1",
      "title": "Schema",
      "type": "string"
    },
    "status": {
      "enum": [
        "ok",
        "degraded",
        "failed"
      ],
      "title": "Status",
      "type": "string"
    },
    "telemetry_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Telemetry Id",
      "type": "string"
    },
    "trace_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Trace Id",
      "type": "string"
    },
    "usage": {
      "$ref": "#/$defs/ResourceVector"
    },
    "workload_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Workload Id"
    }
  },
  "required": [
    "telemetry_id",
    "request_id",
    "trace_id",
    "recorded_at",
    "phase",
    "status",
    "measurement_kind"
  ],
  "title": "TelemetryEvent",
  "type": "object"
}
