{
  "$defs": {
    "ContentReference": {
      "additionalProperties": false,
      "properties": {
        "classification": {
          "default": "private",
          "enum": [
            "public",
            "private",
            "restricted"
          ],
          "title": "Classification",
          "type": "string"
        },
        "media_type": {
          "maxLength": 128,
          "minLength": 3,
          "title": "Media Type",
          "type": "string"
        },
        "sha256": {
          "pattern": "^[a-f0-9]{64}$",
          "title": "Sha256",
          "type": "string"
        },
        "size_bytes": {
          "minimum": 0,
          "title": "Size Bytes",
          "type": "integer"
        },
        "uri": {
          "maxLength": 512,
          "minLength": 8,
          "pattern": "^(artifact|aivm|chal|kc|mem)://[A-Za-z0-9][A-Za-z0-9._~:/?#@!$&'()*+,;=%-]*$",
          "title": "Uri",
          "type": "string"
        }
      },
      "required": [
        "uri",
        "sha256",
        "size_bytes",
        "media_type"
      ],
      "title": "ContentReference",
      "type": "object"
    },
    "RequestConstraints": {
      "additionalProperties": false,
      "properties": {
        "checkpoint_required": {
          "default": false,
          "title": "Checkpoint Required",
          "type": "boolean"
        },
        "deadline": {
          "format": "date-time",
          "title": "Deadline",
          "type": "string"
        },
        "grounding_required": {
          "default": false,
          "title": "Grounding Required",
          "type": "boolean"
        },
        "latency_budget_ms": {
          "maximum": 3600000,
          "minimum": 1,
          "title": "Latency Budget Ms",
          "type": "integer"
        },
        "network_access": {
          "default": "none",
          "enum": [
            "none",
            "artifact_plane_only"
          ],
          "title": "Network Access",
          "type": "string"
        },
        "resources": {
          "$ref": "#/$defs/ResourceVector"
        },
        "template_leakage_allowed": {
          "const": false,
          "default": false,
          "title": "Template Leakage Allowed",
          "type": "boolean"
        }
      },
      "required": [
        "resources",
        "latency_budget_ms",
        "deadline"
      ],
      "title": "RequestConstraints",
      "type": "object"
    },
    "ResourceVector": {
      "additionalProperties": false,
      "properties": {
        "cpu_millicores": {
          "default": 0,
          "minimum": 0,
          "title": "Cpu Millicores",
          "type": "integer"
        },
        "egress_bps": {
          "default": 0,
          "minimum": 0,
          "title": "Egress Bps",
          "type": "integer"
        },
        "gpu_count": {
          "default": 0,
          "minimum": 0,
          "title": "Gpu Count",
          "type": "integer"
        },
        "gpu_memory_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Gpu Memory Bytes",
          "type": "integer"
        },
        "ingress_bps": {
          "default": 0,
          "minimum": 0,
          "title": "Ingress Bps",
          "type": "integer"
        },
        "memory_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Memory Bytes",
          "type": "integer"
        },
        "storage_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Storage Bytes",
          "type": "integer"
        }
      },
      "title": "ResourceVector",
      "type": "object"
    },
    "WorkloadKind": {
      "enum": [
        "retrieval",
        "embedding",
        "indexing",
        "inference",
        "evaluation",
        "simulation",
        "rendering",
        "checkpointable_training"
      ],
      "title": "WorkloadKind",
      "type": "string"
    },
    "WorkloadParameters": {
      "additionalProperties": false,
      "description": "Allowlisted scalar tuning knobs; inputs remain content references.",
      "properties": {
        "batch_size": {
          "anyOf": [
            {
              "maximum": 65536,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Batch Size"
        },
        "checkpoint_interval_seconds": {
          "anyOf": [
            {
              "maximum": 86400,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Checkpoint Interval Seconds"
        },
        "chunk_size": {
          "anyOf": [
            {
              "maximum": 1000000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Chunk Size"
        },
        "deterministic": {
          "default": false,
          "title": "Deterministic",
          "type": "boolean"
        },
        "height": {
          "anyOf": [
            {
              "maximum": 32768,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Height"
        },
        "max_tokens": {
          "anyOf": [
            {
              "maximum": 1000000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Max Tokens"
        },
        "precision": {
          "anyOf": [
            {
              "enum": [
                "auto",
                "fp32",
                "fp16",
                "bf16",
                "int8",
                "int4"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Precision"
        },
        "replica_count": {
          "anyOf": [
            {
              "maximum": 1024,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Replica Count"
        },
        "seed": {
          "anyOf": [
            {
              "maximum": 9223372036854775807,
              "minimum": 0,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Seed"
        },
        "steps": {
          "anyOf": [
            {
              "maximum": 1000000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Steps"
        },
        "temperature": {
          "anyOf": [
            {
              "maximum": 2.0,
              "minimum": 0.0,
              "type": "number"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Temperature"
        },
        "top_k": {
          "anyOf": [
            {
              "maximum": 1000000,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Top K"
        },
        "width": {
          "anyOf": [
            {
              "maximum": 32768,
              "minimum": 1,
              "type": "integer"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Width"
        }
      },
      "title": "WorkloadParameters",
      "type": "object"
    }
  },
  "$id": "https://schemas.reality-core.systems/chal-vsource/v1/chal-request.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "account_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Account Id",
      "type": "string"
    },
    "capability_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Capability Id",
      "type": "string"
    },
    "constraints": {
      "$ref": "#/$defs/RequestConstraints"
    },
    "device_uri": {
      "pattern": "^chal://[A-Za-z0-9._~:/-]+$",
      "title": "Device Uri",
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "idempotency_key": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Idempotency Key",
      "type": "string"
    },
    "inputs": {
      "items": {
        "$ref": "#/$defs/ContentReference"
      },
      "maxItems": 128,
      "title": "Inputs",
      "type": "array"
    },
    "issued_at": {
      "format": "date-time",
      "title": "Issued At",
      "type": "string"
    },
    "parameters": {
      "$ref": "#/$defs/WorkloadParameters"
    },
    "parent_request_id": {
      "anyOf": [
        {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Request Id"
    },
    "request_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Request Id",
      "type": "string"
    },
    "schema": {
      "const": "planetary.chal.request.v1",
      "default": "planetary.chal.request.v1",
      "title": "Schema",
      "type": "string"
    },
    "trace_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Trace Id",
      "type": "string"
    },
    "workload_kind": {
      "$ref": "#/$defs/WorkloadKind"
    },
    "workload_manifest": {
      "$ref": "#/$defs/ContentReference"
    }
  },
  "required": [
    "request_id",
    "trace_id",
    "issued_at",
    "expires_at",
    "idempotency_key",
    "account_id",
    "capability_id",
    "device_uri",
    "workload_kind",
    "workload_manifest",
    "constraints"
  ],
  "title": "ChalRequest",
  "type": "object"
}
