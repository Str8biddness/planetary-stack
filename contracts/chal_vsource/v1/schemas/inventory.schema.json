{
  "$defs": {
    "CpuDescriptor": {
      "additionalProperties": false,
      "properties": {
        "architecture": {
          "enum": [
            "x86_64",
            "aarch64",
            "riscv64"
          ],
          "title": "Architecture",
          "type": "string"
        },
        "features": {
          "items": {
            "maxLength": 64,
            "type": "string"
          },
          "title": "Features",
          "type": "array",
          "uniqueItems": true
        },
        "logical_cores": {
          "maximum": 4096,
          "minimum": 1,
          "title": "Logical Cores",
          "type": "integer"
        }
      },
      "required": [
        "architecture",
        "logical_cores"
      ],
      "title": "CpuDescriptor",
      "type": "object"
    },
    "GpuDescriptor": {
      "additionalProperties": false,
      "properties": {
        "compute_apis": {
          "items": {
            "enum": [
              "cuda",
              "rocm",
              "vulkan",
              "metal",
              "opencl"
            ],
            "type": "string"
          },
          "title": "Compute Apis",
          "type": "array",
          "uniqueItems": true
        },
        "gpu_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "title": "Gpu Id",
          "type": "string"
        },
        "memory_bytes": {
          "minimum": 1,
          "title": "Memory Bytes",
          "type": "integer"
        },
        "model": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "vendor": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Vendor",
          "type": "string"
        }
      },
      "required": [
        "gpu_id",
        "vendor",
        "model",
        "memory_bytes",
        "compute_apis"
      ],
      "title": "GpuDescriptor",
      "type": "object"
    },
    "NodeHealth": {
      "enum": [
        "ready",
        "draining",
        "degraded",
        "offline"
      ],
      "title": "NodeHealth",
      "type": "string"
    },
    "NodeResources": {
      "additionalProperties": false,
      "properties": {
        "allocatable": {
          "$ref": "#/$defs/ResourceVector"
        },
        "capacity": {
          "$ref": "#/$defs/ResourceVector"
        },
        "cpu": {
          "$ref": "#/$defs/CpuDescriptor"
        },
        "gpus": {
          "items": {
            "$ref": "#/$defs/GpuDescriptor"
          },
          "maxItems": 64,
          "title": "Gpus",
          "type": "array"
        }
      },
      "required": [
        "capacity",
        "allocatable",
        "cpu"
      ],
      "title": "NodeResources",
      "type": "object"
    },
    "ResourceVector": {
      "additionalProperties": false,
      "properties": {
        "cpu_millicores": {
          "default": 0,
          "minimum": 0,
          "title": "Cpu Millicores",
          "type": "integer"
        },
        "egress_bps": {
          "default": 0,
          "minimum": 0,
          "title": "Egress Bps",
          "type": "integer"
        },
        "gpu_count": {
          "default": 0,
          "minimum": 0,
          "title": "Gpu Count",
          "type": "integer"
        },
        "gpu_memory_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Gpu Memory Bytes",
          "type": "integer"
        },
        "ingress_bps": {
          "default": 0,
          "minimum": 0,
          "title": "Ingress Bps",
          "type": "integer"
        },
        "memory_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Memory Bytes",
          "type": "integer"
        },
        "storage_bytes": {
          "default": 0,
          "minimum": 0,
          "title": "Storage Bytes",
          "type": "integer"
        }
      },
      "title": "ResourceVector",
      "type": "object"
    },
    "Signature": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "ed25519",
          "default": "ed25519",
          "title": "Algorithm",
          "type": "string"
        },
        "key_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
          "title": "Key Id",
          "type": "string"
        },
        "value": {
          "maxLength": 86,
          "minLength": 86,
          "pattern": "^[A-Za-z0-9_-]{86}$",
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "key_id",
        "value"
      ],
      "title": "Signature",
      "type": "object"
    },
    "TransportKind": {
      "enum": [
        "local_process",
        "unix_socket",
        "lan_mtls",
        "internet_mtls_relay",
        "qualified_rdma"
      ],
      "title": "TransportKind",
      "type": "string"
    },
    "WorkloadKind": {
      "enum": [
        "retrieval",
        "embedding",
        "indexing",
        "inference",
        "evaluation",
        "simulation",
        "rendering",
        "checkpointable_training"
      ],
      "title": "WorkloadKind",
      "type": "string"
    }
  },
  "$id": "https://schemas.reality-core.systems/chal-vsource/v1/inventory.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "account_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Account Id",
      "type": "string"
    },
    "attestation": {
      "enum": [
        "unverified",
        "software_verified",
        "hardware_verified"
      ],
      "title": "Attestation",
      "type": "string"
    },
    "expires_at": {
      "format": "date-time",
      "title": "Expires At",
      "type": "string"
    },
    "health": {
      "$ref": "#/$defs/NodeHealth"
    },
    "inventory_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Inventory Id",
      "type": "string"
    },
    "labels": {
      "additionalProperties": {
        "maxLength": 128,
        "type": "string"
      },
      "maxProperties": 64,
      "title": "Labels",
      "type": "object"
    },
    "node_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$",
      "title": "Node Id",
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "title": "Observed At",
      "type": "string"
    },
    "public_key_fingerprint": {
      "pattern": "^[a-f0-9]{64}$",
      "title": "Public Key Fingerprint",
      "type": "string"
    },
    "resources": {
      "$ref": "#/$defs/NodeResources"
    },
    "schema": {
      "const": "planetary.vsource.inventory.v1",
      "default": "planetary.vsource.inventory.v1",
      "title": "Schema",
      "type": "string"
    },
    "signature": {
      "$ref": "#/$defs/Signature"
    },
    "transports": {
      "items": {
        "$ref": "#/$defs/TransportKind"
      },
      "minItems": 1,
      "title": "Transports",
      "type": "array",
      "uniqueItems": true
    },
    "trust_zone": {
      "const": "personal_cell",
      "default": "personal_cell",
      "title": "Trust Zone",
      "type": "string"
    },
    "workload_kinds": {
      "items": {
        "$ref": "#/$defs/WorkloadKind"
      },
      "minItems": 1,
      "title": "Workload Kinds",
      "type": "array",
      "uniqueItems": true
    }
  },
  "required": [
    "inventory_id",
    "node_id",
    "account_id",
    "public_key_fingerprint",
    "attestation",
    "observed_at",
    "expires_at",
    "health",
    "resources",
    "transports",
    "workload_kinds",
    "signature"
  ],
  "title": "ResourceInventory",
  "type": "object"
}
