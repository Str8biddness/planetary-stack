{
  "$defs": {
    "AttestationLevel": {
      "enum": [
        "unverified",
        "software_verified",
        "hardware_verified"
      ],
      "title": "AttestationLevel",
      "type": "string"
    },
    "CpuDescriptor": {
      "additionalProperties": false,
      "properties": {
        "architecture": {
          "enum": [
            "x86_64",
            "aarch64",
            "riscv64"
          ],
          "title": "Architecture",
          "type": "string"
        },
        "features": {
          "items": {
            "maxLength": 64,
            "pattern": "^[a-z0-9][a-z0-9._-]*$(?![\\s\\S])",
            "type": "string"
          },
          "title": "Features",
          "type": "array",
          "uniqueItems": true,
          "x-canonical-order": "lexicographic"
        },
        "logical_cores": {
          "maximum": 4096,
          "minimum": 1,
          "title": "Logical Cores",
          "type": "integer"
        }
      },
      "required": [
        "architecture",
        "features",
        "logical_cores"
      ],
      "title": "CpuDescriptor",
      "type": "object"
    },
    "GpuDescriptor": {
      "additionalProperties": false,
      "properties": {
        "allocatable_memory_bytes": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Allocatable Memory Bytes",
          "type": "integer"
        },
        "compute_apis": {
          "items": {
            "enum": [
              "cuda",
              "metal",
              "opencl",
              "rocm",
              "vulkan"
            ],
            "type": "string"
          },
          "minItems": 1,
          "title": "Compute Apis",
          "type": "array",
          "uniqueItems": true,
          "x-canonical-order": "lexicographic"
        },
        "model": {
          "maxLength": 128,
          "minLength": 1,
          "title": "Model",
          "type": "string"
        },
        "vendor": {
          "maxLength": 64,
          "minLength": 1,
          "title": "Vendor",
          "type": "string"
        }
      },
      "required": [
        "allocatable_memory_bytes",
        "compute_apis",
        "model",
        "vendor"
      ],
      "title": "GpuDescriptor",
      "type": "object"
    },
    "HostResourceVector": {
      "additionalProperties": false,
      "properties": {
        "cpu_millicores": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Cpu Millicores",
          "type": "integer"
        },
        "egress_bps": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Egress Bps",
          "type": "integer"
        },
        "ingress_bps": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Ingress Bps",
          "type": "integer"
        },
        "memory_bytes": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Memory Bytes",
          "type": "integer"
        },
        "storage_bytes": {
          "maximum": 9007199254740991,
          "minimum": 0,
          "title": "Storage Bytes",
          "type": "integer"
        }
      },
      "required": [
        "cpu_millicores",
        "egress_bps",
        "ingress_bps",
        "memory_bytes",
        "storage_bytes"
      ],
      "title": "HostResourceVector",
      "type": "object"
    },
    "NodeHealth": {
      "enum": [
        "ready",
        "draining",
        "degraded",
        "offline"
      ],
      "title": "NodeHealth",
      "type": "string"
    },
    "NodeLabels": {
      "additionalProperties": false,
      "properties": {
        "network_scope": {
          "anyOf": [
            {
              "enum": [
                "local",
                "trusted_lan",
                "mtls_relay"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Network Scope"
        },
        "power_class": {
          "anyOf": [
            {
              "enum": [
                "battery",
                "consumer",
                "workstation",
                "server"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Power Class"
        },
        "thermal_policy": {
          "anyOf": [
            {
              "enum": [
                "quiet",
                "balanced",
                "performance"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Thermal Policy"
        }
      },
      "required": [
        "network_scope",
        "power_class",
        "thermal_policy"
      ],
      "title": "NodeLabels",
      "type": "object"
    },
    "NodeResources": {
      "additionalProperties": false,
      "properties": {
        "allocatable": {
          "$ref": "#/$defs/HostResourceVector"
        },
        "cpu": {
          "$ref": "#/$defs/CpuDescriptor"
        },
        "gpus": {
          "additionalProperties": false,
          "maxProperties": 64,
          "patternProperties": {
            "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])": {
              "$ref": "#/$defs/GpuDescriptor"
            }
          },
          "propertyNames": {
            "maxLength": 128,
            "minLength": 3
          },
          "title": "Gpus",
          "type": "object"
        }
      },
      "required": [
        "allocatable",
        "cpu",
        "gpus"
      ],
      "title": "NodeResources",
      "type": "object"
    },
    "Signature": {
      "additionalProperties": false,
      "properties": {
        "algorithm": {
          "const": "ed25519",
          "title": "Algorithm",
          "type": "string"
        },
        "key_id": {
          "maxLength": 128,
          "minLength": 3,
          "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
          "title": "Key Id",
          "type": "string"
        },
        "value": {
          "maxLength": 86,
          "minLength": 86,
          "pattern": "^[A-Za-z0-9_-]{86}$(?![\\s\\S])",
          "title": "Value",
          "type": "string"
        }
      },
      "required": [
        "algorithm",
        "key_id",
        "value"
      ],
      "title": "Signature",
      "type": "object"
    },
    "TransportKind": {
      "enum": [
        "local_process",
        "unix_socket",
        "lan_mtls",
        "internet_mtls_relay",
        "qualified_rdma"
      ],
      "title": "TransportKind",
      "type": "string"
    },
    "WorkloadKind": {
      "enum": [
        "retrieval",
        "embedding",
        "indexing",
        "inference",
        "evaluation",
        "simulation",
        "rendering",
        "checkpointable_training"
      ],
      "title": "WorkloadKind",
      "type": "string"
    }
  },
  "$id": "https://schemas.reality-core.systems/chal-vsource/v1/inventory.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "account_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Account Id",
      "type": "string"
    },
    "attestation": {
      "$ref": "#/$defs/AttestationLevel"
    },
    "health": {
      "$ref": "#/$defs/NodeHealth"
    },
    "inventory_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Inventory Id",
      "type": "string"
    },
    "labels": {
      "$ref": "#/$defs/NodeLabels"
    },
    "node_id": {
      "maxLength": 128,
      "minLength": 3,
      "pattern": "^[a-zA-Z0-9][a-zA-Z0-9._:-]+$(?![\\s\\S])",
      "title": "Node Id",
      "type": "string"
    },
    "observed_at": {
      "format": "date-time",
      "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01])T([01][0-9]|2[0-3]):[0-5][0-9]:[0-5][0-9]Z$(?![\\s\\S])",
      "title": "Observed At",
      "type": "string"
    },
    "public_key_fingerprint": {
      "pattern": "^[a-f0-9]{64}$(?![\\s\\S])",
      "title": "Public Key Fingerprint",
      "type": "string"
    },
    "resources": {
      "$ref": "#/$defs/NodeResources"
    },
    "schema": {
      "const": "planetary.vsource.inventory.v1",
      "title": "Schema",
      "type": "string"
    },
    "signature": {
      "$ref": "#/$defs/Signature"
    },
    "transports": {
      "items": {
        "$ref": "#/$defs/TransportKind"
      },
      "minItems": 1,
      "title": "Transports",
      "type": "array",
      "uniqueItems": true,
      "x-canonical-order": "lexicographic"
    },
    "trust_zone": {
      "const": "personal_cell",
      "title": "Trust Zone",
      "type": "string"
    },
    "ttl_seconds": {
      "maximum": 300,
      "minimum": 1,
      "title": "Ttl Seconds",
      "type": "integer"
    },
    "workload_kinds": {
      "items": {
        "$ref": "#/$defs/WorkloadKind"
      },
      "minItems": 1,
      "title": "Workload Kinds",
      "type": "array",
      "uniqueItems": true,
      "x-canonical-order": "lexicographic"
    }
  },
  "required": [
    "account_id",
    "attestation",
    "health",
    "inventory_id",
    "labels",
    "node_id",
    "observed_at",
    "public_key_fingerprint",
    "resources",
    "schema",
    "signature",
    "transports",
    "trust_zone",
    "ttl_seconds",
    "workload_kinds"
  ],
  "title": "ResourceInventory",
  "type": "object",
  "x-planetary-semantic-invariants": [
    "Verify Ed25519 and node-key ownership; inventory expires at observed_at + ttl_seconds.",
    "The gpus object is keyed by unique GPU IDs and publishes allocatable rather than physical capacity.",
    "Canonical-order arrays are unique and lexicographically sorted."
  ]
}
